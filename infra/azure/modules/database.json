{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "2802147221587481878"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region"
      }
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Environment tag"
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL admin password. Required — no default. Not used to modify server (existing)."
      }
    }
  },
  "variables": {
    "serverName": "[format('sira-db-{0}', parameters('environment'))]",
    "adminLogin": "sira_admin",
    "databaseName": "sira"
  },
  "resources": [
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2022-12-01",
      "name": "[format('{0}/{1}', variables('serverName'), variables('databaseName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2022-12-01",
      "name": "[format('{0}/{1}', variables('serverName'), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      }
    }
  ],
  "outputs": {
    "serverName": {
      "type": "string",
      "value": "[variables('serverName')]"
    },
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('serverName')), '2022-12-01').fullyQualifiedDomainName]"
    },
    "adminLogin": {
      "type": "string",
      "value": "[variables('adminLogin')]"
    },
    "databaseName": {
      "type": "string",
      "value": "[variables('databaseName')]"
    }
  }
}