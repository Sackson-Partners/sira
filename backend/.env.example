# SIRA Platform Environment Configuration - Phase 2 MVP
# Copy this file to .env and update with your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=SIRA Platform
APP_VERSION=2.0.0
DEBUG=True
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# SQLite for local development (no setup required):
DATABASE_URL=sqlite:///./sira_dev.db
# PostgreSQL for production (uncomment and configure):
# DATABASE_URL=postgresql://sira_user:sira_password@localhost:5432/sira_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# SECURITY - CHANGE THESE IN PRODUCTION!
# =============================================================================
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS SETTINGS
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@sira-platform.com
EMAIL_FROM_NAME=SIRA Platform

# =============================================================================
# FILE STORAGE
# =============================================================================
STORAGE_TYPE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# MONITORING
# =============================================================================
# SENTRY_DSN=https://your-sentry-dsn
PROMETHEUS_ENABLED=False

# =============================================================================
# PHASE 2: FLESPI TELEMATICS (MQTT)
# =============================================================================
# Get your token from https://flespi.io
# FLESPI_TOKEN=your-flespi-token
FLESPI_MQTT_HOST=mqtt.flespi.io
FLESPI_MQTT_PORT=1883
FLESPI_REST_URL=https://flespi.io

# =============================================================================
# PHASE 2: MARINETRAFFIC AIS
# =============================================================================
# Get your API key from https://www.marinetraffic.com/en/ais-api-services
# MARINETRAFFIC_API_KEY=your-marinetraffic-api-key
MARINETRAFFIC_API_URL=https://services.marinetraffic.com/api

# =============================================================================
# PHASE 2: AI INTELLIGENCE ENGINE
# =============================================================================
# Set at least one: Anthropic (Claude) preferred, OpenAI as fallback
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# =============================================================================
# PHASE 2: MAPBOX
# =============================================================================
# Get your token from https://account.mapbox.com/access-tokens/
# MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
