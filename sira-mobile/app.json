{
  "expo": {
    "name": "SIRA",
    "slug": "sira-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060E1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sira.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SIRA needs location to track shipment checkpoints.",
        "NSLocationAlwaysUsageDescription": "SIRA needs background location for active shipment tracking.",
        "NSCameraUsageDescription": "SIRA needs camera access to capture evidence photos.",
        "NSPhotoLibraryUsageDescription": "SIRA needs photo library access to upload evidence."
      },
      "config": {
        "googleMapsApiKey": "$(GOOGLE_MAPS_IOS_KEY)"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060E1E"
      },
      "package": "com.sira.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$(GOOGLE_MAPS_ANDROID_KEY)"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SIRA uses location to track active shipments."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0A1F44"
        }
      ]
    ],
    "scheme": "sira",
    "extra": {
      "eas": {
        "projectId": "sira-mobile"
      },
      "API_BASE_URL": "https://api.sira.io/api/v1"
    }
  }
}
