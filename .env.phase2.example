# =============================================================================
# SIRA Platform — Phase 2 Environment Variables
# Copy to .env.phase2 and fill in your values
# NEVER commit .env.phase2 — it is gitignored
# Production secrets MUST be stored in Azure Key Vault
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sira:your_password@localhost:5432/sira_db
POSTGRES_PASSWORD=your_secure_password

# --- Supabase (Authentication) ---
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_ANON_KEY=your_anon_key_here

# --- Frontend (Vercel env vars) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
NEXT_PUBLIC_API_URL=https://sira-api-prod.yourcontainerapp.azurecontainerapps.io

# --- AI / LLM ---
# Claude API: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your_claude_api_key

# OpenAI (fallback): https://platform.openai.com
OPENAI_API_KEY=sk-your_openai_api_key

# --- Telematics (Flespi) ---
# Get from: https://flespi.io/tokens
FLESPI_TOKEN=your_flespi_token

# --- Maritime (MarineTraffic) ---
# Get from: https://www.marinetraffic.com/en/ais/api
MARINE_TRAFFIC_API_KEY=your_marinetraffic_api_key

# --- Maps (Mapbox) ---
# Server-side secret token (NOT the public token)
MAPBOX_SECRET_TOKEN=sk.your_mapbox_secret_token

# --- Market Data ---
MARKET_DATA_API_KEY=your_quandl_or_refinitiv_key

# --- Azure (for CI/CD) ---
# Used by GitHub Actions azure-deploy.yml
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_SUBSCRIPTION_SUFFIX=your_unique_suffix_for_acr_name
# AZURE_CREDENTIALS is a JSON object stored as GitHub Secret

# --- Redis (optional caching) ---
REDIS_URL=redis://localhost:6379

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=debug
SECRET_KEY=your_secret_key_for_session_signing
